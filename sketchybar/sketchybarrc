#!/bin/bash

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          GENTLEMAN SKETCHYBAR                                 ║
# ║                    Minimal Islands - Floating Style                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"

# ─────────────────────────────────────────────────────────────────────────────────
# GENTLEMAN COLOR PALETTE (matching Ghostty/Neovim theme)
# ─────────────────────────────────────────────────────────────────────────────────
export BLACK=0xff06080f
export WHITE=0xfff3f6f9
export RED=0xffcb7c94
export GREEN=0xffb7cc85
export YELLOW=0xffffe066
export ORANGE=0xfffff7b1
export BLUE=0xff7fb4ca
export MAGENTA=0xffff8dd7
export CYAN=0xff7aa89f
export TRANSPARENT=0x00000000

# Island colors
export ISLAND_BG=0xff121620
export ISLAND_BORDER=0xff263356
export ACCENT_COLOR=0xffe0c15a
export DIM=0xff565f89

# ─────────────────────────────────────────────────────────────────────────────────
# BAR APPEARANCE (transparent base for floating islands)
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --bar \
  height=45 \
  blur_radius=0 \
  position=top \
  sticky=on \
   padding_left=4 \
   padding_right=4 \
  color=$TRANSPARENT \
  corner_radius=0 \
  y_offset=-50 \
  margin=0 \
  notch_width=280 \
  notch_offset=0

# Startup animation - slide down from top
sketchybar --animate sin 12 --bar y_offset=-50 y_offset=2

# ─────────────────────────────────────────────────────────────────────────────────
# DEFAULT VALUES
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --default \
  icon.font="IosevkaTerm NFM:Bold:14.0" \
  icon.color=$WHITE \
  label.font="IosevkaTerm NFM:Medium:13.0" \
  label.color=$WHITE \
  background.color=$ISLAND_BG \
  background.border_color=$ISLAND_BORDER \
  background.border_width=1 \
  background.corner_radius=12 \
  background.height=32 \
  padding_left=6 \
  padding_right=6 \
  label.padding_left=6 \
  label.padding_right=8 \
  icon.padding_left=10 \
  icon.padding_right=4

# ═══════════════════════════════════════════════════════════════════════════════
#                                LEFT SIDE
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# SPACES (YABAI WORKSPACES)
# ─────────────────────────────────────────────────────────────────────────────────
# Add yabai events
sketchybar --add event yabai_space_changed
sketchybar --add event yabai_window_created
sketchybar --add event yabai_window_destroyed
sketchybar --add event yabai_window_moved


# ─────────────────────────────────────────────────────────────────────────────────
# FRONT APP (Active Application)
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item front_app left \
  --set front_app \
    icon.drawing=off \
    label.drawing=on \
    padding_left=8 \
    padding_right=8 \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    script="$PLUGIN_DIR/front_app.sh" \
  --subscribe front_app front_app_switched

# ─────────────────────────────────────────────────────────────────────────────────
# MUSIC
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item music left \
  --set music \
    icon="MUS" \
    icon.font="IosevkaTerm NF:Bold:10.0" \
    icon.color=$GREEN \
    icon.padding_left=10 \
    icon.padding_right=4 \
    label.padding_right=10 \
    label.max_chars=17 \
    scroll_texts=on \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    update_freq=3 \
    script="$PLUGIN_DIR/music.sh" \
    click_script="open -a Spotify"

# ═══════════════════════════════════════════════════════════════════════════════
#                                RIGHT SIDE
# ═══════════════════════════════════════════════════════════════════════════════
# Order (right to left): Battery | DateTime | Volume | Mic | RAM
# LEFT sidebar: Front App | Music

# ─────────────────────────────────────────────────────────────────────────────────
# DATETIME
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item datetime right \
  --set datetime \
    icon="CAL" \
    icon.font="IosevkaTerm NF:Bold:10.0" \
    icon.color=$YELLOW \
    icon.padding_left=10 \
    icon.padding_right=4 \
    label.padding_right=10 \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    update_freq=10 \
    script="$PLUGIN_DIR/datetime.sh" \
    click_script="open -a Calendar"

# ─────────────────────────────────────────────────────────────────────────────────
# BATTERY (rightmost)
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item battery right \
  --set battery \
    icon.font="IosevkaTerm NF:Bold:14.0" \
    icon.color=$GREEN \
    icon.padding_left=10 \
    icon.padding_right=4 \
    label.padding_right=10 \
    label.width=40 \
    label.align=right \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    update_freq=60 \
    script="$PLUGIN_DIR/battery.py" \
    click_script="open -a 'System Preferences' /System/Library/PreferencePanes/Battery.prefPane" \
  --subscribe battery system_woke power_source_change

# ─────────────────────────────────────────────────────────────────────────────────
# WIFI (connection status)
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item wifi right \
  --set wifi \
    icon="◈" \
    icon.font="IosevkaTerm NF:Bold:12.0" \
    icon.color=$BLUE \
    icon.padding_left=8 \
    icon.padding_right=2 \
    label.padding_left=0 \
    label.padding_right=8 \
    label.max_chars=15 \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    update_freq=5 \
    script="$PLUGIN_DIR/connectivity.py" \
    click_script="open -a 'System Preferences' /System/Library/PreferencePanes/Network.prefPane" \
  --subscribe wifi wifi_change

# ─────────────────────────────────────────────────────────────────────────────────
# BLUETOOTH (connection status)
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item bluetooth right \
  --set bluetooth \
    icon="BT" \
    icon.font="IosevkaTerm NF:Bold:14.0" \
    icon.color=$MAGENTA \
    icon.padding_left=8 \
    icon.padding_right=2 \
    label.padding_left=0 \
    label.padding_right=8 \
    label.max_chars=12 \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    update_freq=3 \
    script="$PLUGIN_DIR/connectivity.py" \
    click_script="open -a 'System Preferences' /System/Library/PreferencePanes/Bluetooth.prefPane" \
  --subscribe bluetooth system_woke

# Pomodoro Timer Item
sketchybar --add item pomodoro right \
  --set pomodoro \
    icon="" \
    label.padding_right=6 \
    icon.padding_left=0 \
    icon.padding_right=2 \
    icon.color=0xffff0000 \
    label.color=0xffffff00 \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    update_freq=1 \
    script="$CONFIG_DIR/plugins/pomodoro.py" \
  --subscribe pomodoro system_woke

# ─────────────────────────────────────────────────────────────────────────────────
# VOLUME
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item volume right \
  --set volume \
    icon="VOL" \
    icon.font="IosevkaTerm NF:Bold:10.0" \
    icon.color=$BLUE \
    icon.padding_left=8 \
    icon.padding_right=2 \
    label.padding_left=0 \
    label.padding_right=8 \
    label.width=30 \
    label.align=right \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    script="$PLUGIN_DIR/volume.sh" \
    click_script="open -a 'System Preferences' /System/Library/PreferencePanes/Sound.prefPane" \
  --subscribe volume volume_change

# ─────────────────────────────────────────────────────────────────────────────────
# MIC (microphone status) - click to toggle mute
# ─────────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────────
# GITHUB NOTIFICATIONS
# ─────────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────────
# CPU
# ─────────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────────────────────────────────────────
# RAM
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item ram right \
  --set ram \
    icon="RAM" \
    icon.font="IosevkaTerm NF:Bold:10.0" \
    icon.color=$MAGENTA \
    icon.padding_left=10 \
    icon.padding_right=4 \
    label.padding_right=10 \
    label.width=40 \
    label.align=right \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    update_freq=5 \
    script="$PLUGIN_DIR/system-stats.py" \
  click_script="open -a 'Activity Monitor'" \

# ─────────────────────────────────────────────────────────────────────────────────
# CPU (processor usage)
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add item cpu right \
  --set cpu \
    icon="CPU" \
    icon.font="IosevkaTerm NF:Bold:10.0" \
    icon.color=$RED \
    icon.padding_left=10 \
    icon.padding_right=4 \
    label.padding_right=10 \
    label.width=40 \
    label.align=right \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=4 \
    background.height=24 \
    update_freq=5 \
    script="$PLUGIN_DIR/system-stats.py" \
    click_script="open -a 'Activity Monitor'"

# GPU Display Item
sketchybar --add item gpu right \
  --set gpu \
    icon=󰨸 \
    icon.color=0xff00aa00 \
    label.color=0xffffff00 \
    update_freq=2 \
    script="$PLUGIN_DIR/system-stats.py" \
  --subscribe gpu system_woke

# ─────────────────────────────────────────────────────────────────────────────────
# MAIL
# ─────────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────────
# HAPPY HACKING
# ─────────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────────
# FINALIZE
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --update
