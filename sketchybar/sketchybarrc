#!/bin/bash

# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║                          GENTLEMAN SKETCHYBAR                                 ║
# ║                    Premium Islands - Floating Style                           ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

CONFIG_DIR="$HOME/.config/sketchybar"
PLUGIN_DIR="$CONFIG_DIR/plugins"

# ─────────────────────────────────────────────────────────────────────────────────
# GENTLEMAN COLOR PALETTE
# ─────────────────────────────────────────────────────────────────────────────────
export BLACK=0xff06080f
export WHITE=0xfff3f6f9
export RED=0xffcb7c94
export GREEN=0xffb7cc85
export YELLOW=0xffffe066
export ORANGE=0xfffff7b1
export BLUE=0xff7fb4ca
export MAGENTA=0xffff8dd7
export CYAN=0xff7aa89f
export TRANSPARENT=0x00000000

# Island colors
export ISLAND_BG=0xff121620
export ISLAND_BORDER=0xff263356
export ISLAND_HOVER=0xff44506c
export ACCENT_COLOR=0xffe0c15a
export DIM=0xff565f89

# ─────────────────────────────────────────────────────────────────────────────────
# BAR APPEARANCE
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --bar \
  height=40 \
  blur_radius=30 \
  position=top \
  sticky=on \
  padding_left=10 \
  padding_right=10 \
  color=$TRANSPARENT \
  y_offset=4 \
  margin=0 \
  corner_radius=0

# ─────────────────────────────────────────────────────────────────────────────────
# DEFAULT VALUES (Premium Spacing)
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --default \
  icon.font="FiraCode Nerd Font:Bold:15.0" \
  icon.color=$WHITE \
  label.font="FiraCode Nerd Font:SemiBold:13.0" \
  label.color=$WHITE \
  background.color=$TRANSPARENT \
  background.height=28 \
  padding_left=4 \
  padding_right=4 \
  label.padding_left=4 \
  label.padding_right=8 \
  icon.padding_left=8 \
  icon.padding_right=4

# ═══════════════════════════════════════════════════════════════════════════════
#                                LEFT SIDE
# ═══════════════════════════════════════════════════════════════════════════════

# FRONT APP
sketchybar --add item front_app left \
  --set front_app \
    icon.drawing=off \
    label.color=$WHITE \
    script="$PLUGIN_DIR/front_app.py" \
  --subscribe front_app front_app_switched window_focus

# MUSIC
sketchybar --add item music left \
  --set music \
    icon="🎧" \
    icon.color=$GREEN \
    label.max_chars=25 \
    scroll_texts=on \
    update_freq=5 \
    script="$PLUGIN_DIR/music.py" \
    click_script="sketchybar --set music popup.drawing=toggle" \
  --subscribe music mouse.clicked

# RADIO
sketchybar --add item radio left \
  --set radio \
    icon="📻" \
    icon.color=$ORANGE \
    label.max_chars=20 \
    script="$PLUGIN_DIR/radio.py" \
    click_script="SENDER=mouse.clicked $PLUGIN_DIR/radio.py" \
  --subscribe radio mouse.entered mouse.exited mouse.clicked

# ═══════════════════════════════════════════════════════════════════════════════
#                                RIGHT SIDE
# ═══════════════════════════════════════════════════════════════════════════════

sketchybar --add item battery right \
  --set battery \
    update_freq=60 \
    script="$PLUGIN_DIR/battery.py" \
    click_script="open -a 'System Preferences' /System/Library/PreferencePanes/Battery.prefPane" \
  --subscribe battery system_woke power_source_change
sketchybar --add item datetime right \
  --set datetime \
    icon.drawing=off \
    label.width=135 \
    label.align=right \
    update_freq=60 \
    script="$PLUGIN_DIR/calendar.py" \
    click_script="SENDER=mouse.clicked $PLUGIN_DIR/calendar.py" \
  --subscribe datetime system_woke mouse.clicked routine


sketchybar --add item wifi right \
  --set wifi \
    icon.color=$BLUE \
    update_freq=5 \
    script="$PLUGIN_DIR/connectivity.py" \
    click_script="open -a 'System Preferences' /System/Library/PreferencePanes/Network.prefPane" \
  --subscribe wifi wifi_change

sketchybar --add item bluetooth right \
  --set bluetooth \
    icon.color=$MAGENTA \
    update_freq=3 \
    script="$PLUGIN_DIR/connectivity.py" \
    click_script="open -a 'System Preferences' /System/Library/PreferencePanes/Bluetooth.prefPane" \
  --subscribe bluetooth system_woke

sketchybar --add item volume right \
  --set volume \
    icon.color=$CYAN \
    update_freq=1 \
    script="$PLUGIN_DIR/volume.py" \
    click_script="open 'x-apple.systempreferences:com.apple.preference.sound'" \
  --subscribe volume volume_change

sketchybar --add item ram right \
  --set ram \
    icon="󰘚" \
    icon.color=$CYAN \
    update_freq=5 \
    script="$PLUGIN_DIR/system-stats.py" \
    click_script="open -a 'Activity Monitor'"

sketchybar --add item cpu right \
  --set cpu \
    icon="󰍛" \
    icon.color=$YELLOW \
    update_freq=5 \
    script="$PLUGIN_DIR/system-stats.py"

sketchybar --add item gpu right \
  --set gpu \
    icon="󰢮" \
    icon.color=$GREEN \
    update_freq=5 \
    script="$PLUGIN_DIR/system-stats.py"

sketchybar --add item pomodoro right \
  --set pomodoro \
    update_freq=1 \
    script="$PLUGIN_DIR/pomodoro.py" \
    click_script="$PLUGIN_DIR/pomodoro.py" \
  --subscribe pomodoro system_woke mouse.clicked

# ─────────────────────────────────────────────────────────────────────────────────
# BRACKETS (Floating Islands - Enhanced Visuals)
# ─────────────────────────────────────────────────────────────────────────────────
sketchybar --add bracket media music radio \
  --set media \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=10 \
    background.height=30

sketchybar --add bracket system battery datetime \
  --set system \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=10 \
    background.height=30

sketchybar --add bracket connectivity wifi bluetooth volume \
  --set connectivity \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=10 \
    background.height=30

sketchybar --add bracket stats ram cpu gpu \
  --set stats \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=10 \
    background.height=30

sketchybar --add bracket pomo pomodoro \
  --set pomo \
    background.color=$ISLAND_BG \
    background.border_color=$ISLAND_BORDER \
    background.border_width=1 \
    background.corner_radius=10 \
    background.height=30

# Mouse effects for islands
sketchybar --set media mouse.entered_action="sketchybar --set media background.border_color=$ACCENT_COLOR" \
           --set media mouse.exited_action="sketchybar --set media background.border_color=$ISLAND_BORDER"

sketchybar --set system mouse.entered_action="sketchybar --set system background.border_color=$ACCENT_COLOR" \
           --set system mouse.exited_action="sketchybar --set system background.border_color=$ISLAND_BORDER"

sketchybar --set connectivity mouse.entered_action="sketchybar --set connectivity background.border_color=$ACCENT_COLOR" \
           --set connectivity mouse.exited_action="sketchybar --set connectivity background.border_color=$ISLAND_BORDER"

sketchybar --set stats mouse.entered_action="sketchybar --set stats background.border_color=$ACCENT_COLOR" \
           --set stats mouse.exited_action="sketchybar --set stats background.border_color=$ISLAND_BORDER"

sketchybar --set pomo mouse.entered_action="sketchybar --set pomo background.border_color=$ACCENT_COLOR" \
           --set pomo mouse.exited_action="sketchybar --set pomo background.border_color=$ISLAND_BORDER"

sketchybar --update
